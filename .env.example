# Obligatoria para usar Abacus como proveedor principal (puede ir también desde UI)
ABACUS_API_KEY=
# Requerido por getChatResponse (si usás deployment de Abacus). También configurable desde UI.
ABACUS_DEPLOYMENT_ID=

# Opcionales (si no se cargan en UI)
GROQ_API_KEY=
GEMINI_API_KEY=

# Ruta opcional para persistencia JSON local (dev/self-host)
DATA_DIR=./data
